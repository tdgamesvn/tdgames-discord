# ── DISCORD ──────────────────────────────────────────────────────────────────

# Bot token lấy từ Discord Developer Portal > Bot > Token
DISCORD_TOKEN=your-bot-token-here

# Application ID lấy từ Discord Developer Portal > General Information
DISCORD_CLIENT_ID=your-client-id-here

# Channel ID nhận thông báo lỗi (để trống nếu không dùng)
ERROR_CHANNEL_ID=

# ── CLIPROXY ─────────────────────────────────────────────────────────────────

# URL của CLIProxy service (bao gồm host và port)
CLIPROXY_API_URL=http://localhost:8317

# API key để xác thực với CLIProxy
CLIPROXY_API_KEY=your-cliproxy-api-key-here

# ── SESSION ───────────────────────────────────────────────────────────────────

# Số message tối đa lưu trong lịch sử mỗi session
SESSION_HISTORY_LIMIT=10

# Thời gian session tự động hết hạn (đơn vị: phút)
SESSION_EXPIRE_MINUTES=30

# ── QUEUE ─────────────────────────────────────────────────────────────────────

# Số request tối đa đang chờ xử lý trong queue mỗi channel
CHANNEL_QUEUE_MAX_PENDING=5

# ─── Feature: Image Generation ─────────────────────────────────────────────────
IMAGE_CHANNEL_IDS=111,222
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=auto

# ─── Feature: Text Chat ──────────────────────────────────────────────────────────
CHAT_CHANNEL_IDS=333,444
CHAT_MODEL=gpt-4o-mini
CHAT_FALLBACK_MODEL=gpt-4o-mini

# ─── Feature: Upscaler ───────────────────────────────────────────────────────
UPSCALE_CHANNEL_IDS=
UPSCAYL_BIN_PATH=/Applications/Upscayl.app/Contents/Resources/bin/upscayl-bin
UPSCAYL_MODELS_PATH=/Applications/Upscayl.app/Contents/Resources/models
UPSCALE_SCALE=4
UPSCALE_MODEL=upscayl-standard-4x

# ─── Feature: Upscaler (Video) ───────────────────────────────────────────────
# Channel riêng cho upscale video — tách hẳn khỏi flow ảnh ở trên.
# Dùng lại cùng binary/model Real-ESRGAN (UPSCAYL_BIN_PATH/MODELS_PATH/SCALE/MODEL) ở trên,
# tách frame bằng ffmpeg, upscale từng frame, ghép lại video + audio gốc.
# Cần cài ffmpeg: `brew install ffmpeg`.
UPSCALER_VIDEO_CHANNEL_IDS=
UPSCALE_VIDEO_MAX_DURATION_SEC=20

# ─── Feature: Compressor (Ảnh + Video) ───────────────────────────────────────
# Channel riêng — tự nhận diện user gửi ảnh hay video để nén tương ứng.
# Dùng lại ffmpeg (FFMPEG_PATH ở trên). Ảnh convert sang WebP lossy chất lượng
# cao; video recompress H.264 CRF (số càng thấp chất lượng càng cao, file càng lớn).
COMPRESSOR_CHANNEL_IDS=
COMPRESS_IMAGE_QUALITY=85
COMPRESS_VIDEO_CRF=23
COMPRESS_VIDEO_PRESET=medium

# ─── Feature: Chat Storage ───────────────────────────────────────────────────
# Lưu realtime message create/update/delete vào SQLite data/bot.db.
# Feature này không route/reply theo channel; nó chạy song song với router.
CHAT_STORAGE_ENABLED=false
CHAT_STORAGE_INCLUDE_BOTS=false

# ─── Discord History Backfill ─────────────────────────────────────────────────
# Chạy chậm từng phần để tránh Discord API rate limit.
DISCORD_BACKFILL_MONTHS=6
DISCORD_BACKFILL_MAX_MESSAGES_PER_RUN=1000
DISCORD_BACKFILL_BATCH_SIZE=100
DISCORD_BACKFILL_DELAY_MS=1500

# ── CONFIG UI (optional) ──────────────────────────────────────────────────────

# Port cho Config UI web server
CONFIG_UI_PORT=3456

# ── OPENAI FALLBACK (optional) ────────────────────────────────────────────────

# OpenAI API key để fallback khi CLIProxy lỗi (để trống nếu không dùng)
OPENAI_API_KEY=

# OpenAI API URL (để trống dùng mặc định: https://api.openai.com)
# OPENAI_API_URL=https://api.openai.com
